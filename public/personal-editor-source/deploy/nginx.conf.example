# Nginx configuration for Blog Editor
# File: /etc/nginx/sites-available/blog-editor
# Sau khi chỉnh sửa, enable bằng:
#   sudo ln -s /etc/nginx/sites-available/blog-editor /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;

    # Đổi thành tên miền của bạn
    server_name your-domain.com www.your-domain.com;

    root /var/www/blog-editor;
    index index.html;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        image/svg+xml;

    # Cache static assets aggressively
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # HTML — shorter cache (so updates reach users faster)
    location ~* \.html$ {
        expires 5m;
        add_header Cache-Control "public, must-revalidate";
    }

    # Main route
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Hide hidden files
    location ~ /\. {
        deny all;
    }

    # Logs
    access_log /var/log/nginx/blog-editor-access.log;
    error_log  /var/log/nginx/blog-editor-error.log;
}

# Sau khi chạy `certbot --nginx -d your-domain.com`,
# Certbot sẽ tự thêm block HTTPS và redirect 80 -> 443 ở đây.
